const PACK_COLORS: Record<string, string> = {
  'Free': 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  'Pro': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  'Expert': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  'Admin': 'bg-slate-500/20 text-slate-400 border-slate-500/30',
  'Tous': 'bg-amber-500/20 text-amber-400 border-amber-500/30',
};

export default function FeaturesShowcase() {
  const [activeCategory, setActiveCategory] = useState<'all' | 'Free' | 'Pro' | 'Expert'>('all');
  const [expanded, setExpanded] = useState<number | null>(null);

  const filtered = activeCategory === 'all'
    ? FEATURES
    : FEATURES.filter(f => f.pack === activeCategory || f.pack === 'Tous' || f.pack === 'Free');

  return (
    <section className="py-16 px-6 bg-slate-950">
      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <motion.div initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true }} className="text-center mb-12">
          <span className="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-xs text-blue-400 font-medium mb-4">
            <Sparkles className="w-3 h-3" /> 17 fonctionnalités professionnelles
          </span>
          <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">
            Tout ce dont vous avez besoin pour <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-400">trader comme un pro</span>
          </h2>
          <p className="text-slate-400 max-w-2xl mx-auto text-sm leading-relaxed">
            Chaque fonctionnalité est conçue pour vous donner un avantage compétitif. De l'analyse IA aux données institutionnelles, 
            en passant par la gestion des risques — tout est là.
          </p>
        </motion.div>

        {/* Filter tabs */}
        <div className="flex justify-center gap-2 mb-10">
          {(['all', 'Free', 'Pro', 'Expert'] as const).map(cat => (
            <button key={cat} onClick={() => setActiveCategory(cat)}
              className={`px-4 py-2 rounded-xl text-sm font-medium transition-colors ${activeCategory === cat ? 'bg-blue-500/20 text-blue-400 border border-blue-500/30' : 'bg-slate-900/60 border border-slate-800 text-slate-400 hover:text-white'}`}>
              {cat === 'all' ? 'Toutes' : cat === 'Free' ? 'Gratuit' : cat}
            </button>
          ))}
        </div>

        {/* Features Grid */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {filtered.map((feature, i) => {
            const Icon = feature.icon;
            const isExpanded = expanded === i;
            return (
              <motion.div
                key={i}
                initial={{ opacity: 0, y: 20 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ delay: i * 0.03 }}
                className={`bg-gradient-to-br ${feature.bg} border rounded-2xl overflow-hidden cursor-pointer transition-all hover:scale-[1.02]`}
                onClick={() => setExpanded(isExpanded ? null : i)}
              >
                <div className="p-5">
                  <div className="flex items-start justify-between mb-3">
                    <div className="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                      <Icon className={`w-5 h-5 ${feature.color}`} />
                    </div>
                    <span className={`px-2 py-0.5 rounded-full text-[10px] font-medium border ${PACK_COLORS[feature.pack]}`}>
                      {feature.pack === 'Free' ? 'Gratuit' : feature.pack}
                    </span>
                  </div>

                  <h3 className="text-base font-bold text-white mb-1">{feature.title}</h3>
                  <p className="text-xs text-slate-400 leading-relaxed mb-3">{feature.description}</p>

                  {feature.highlight && (
                    <span className={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gradient-to-r ${feature.bg} text-[10px] ${feature.color} font-medium mb-2`}>
                      <Star className="w-3 h-3" /> {feature.highlight}
                    </span>
                  )}

                  <AnimatePresence>
                    {isExpanded && (
                      <motion.div initial={{ height: 0, opacity: 0 }} animate={{ height: 'auto', opacity: 1 }} exit={{ height: 0, opacity: 0 }} className="overflow-hidden">
                        <div className="mt-3 pt-3 border-t border-white/10 space-y-1.5">
                          {feature.capabilities.map((cap, j) => (
                            <div key={j} className="flex items-center gap-2">
                              <Check className="w-3 h-3 text-emerald-400 flex-shrink-0" />
                              <span className="text-xs text-slate-300">{cap}</span>
                            </div>
                          ))}
                        </div>
                      </motion.div>
                    )}
                  </AnimatePresence>

                  <p className="text-[10px] text-slate-600 mt-2">{isExpanded ? 'Cliquez pour replier' : 'Cliquez pour voir les capacités'}</p>
                </div>
              </motion.div>
            );
          })}
        </div>

        {/* Comparison Table */}
        <motion.div initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true }} className="mt-16">
          <h3 className="text-2xl font-bold text-white text-center mb-8">Comparez les packs</h3>
          <div className="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="border-b border-slate-800">
                  <th className="px-4 py-3 text-left text-slate-400 font-medium">Fonctionnalité</th>
                  <th className="px-4 py-3 text-center text-emerald-400 font-medium">Free</th>
                  <th className="px-4 py-3 text-center text-blue-400 font-medium">Pro</th>
                  <th className="px-4 py-3 text-center text-purple-400 font-medium">Expert</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['Dashboard temps réel', true, true, true],
                  ['Signaux IA (Entry/SL/TP)', true, true, true],
                  ['Analyse Technique', true, true, true],
                  ['Sentiment & Volatilité', true, true, true],
                  ['Alertes Prix', true, true, true],
                  ['News Center IA', true, true, true],
                  ['Gestion des Risques', true, true, true],
                  ['Radar Opportunités', false, true, true],
                  ['Scanner Marché', false, true, true],
                  ['Multi-Actifs', false, true, true],
                  ['Centre Décision Institutionnel', false, true, true],
                  ['Centre Décision Rentabilité', false, true, true],
                  ['Simulateur & Strategy Lab', false, true, true],
                  ['Smart Money Tracker', false, false, true],
                  ['Assistant IA (4 providers)', false, false, true],
                  ['MT4/MT5 Export', false, false, true],
                ].map(([feature, free, pro, expert], i) => (
                  <tr key={i} className="border-b border-slate-800/50">
                    <td className="px-4 py-2.5 text-slate-300">{feature as string}</td>
                    <td className="px-4 py-2.5 text-center">{free ? <Check className="w-4 h-4 text-emerald-400 mx-auto" /> : <XCircle className="w-4 h-4 text-slate-700 mx-auto" />}</td>
                    <td className="px-4 py-2.5 text-center">{pro ? <Check className="w-4 h-4 text-blue-400 mx-auto" /> : <XCircle className="w-4 h-4 text-slate-700 mx-auto" />}</td>
                    <td className="px-4 py-2.5 text-center">{expert ? <Check className="w-4 h-4 text-purple-400 mx-auto" /> : <XCircle className="w-4 h-4 text-slate-700 mx-auto" />}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </motion.div>

        {/* CTA */}
        <motion.div initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true }} className="text-center mt-12">
          <p className="text-slate-400 text-sm mb-4">Commencez gratuitement. Passez à Pro quand vous serez prêt.</p>
          <div className="flex items-center justify-center gap-3">
            <button className="flex items-center gap-2 px-6 py-3 bg-blue-500 text-white rounded-xl text-sm font-medium hover:bg-blue-600 transition-colors">
              <Crown className="w-4 h-4" /> Essai Gratuit
            </button>
            <button className="flex items-center gap-2 px-6 py-3 bg-slate-800 text-slate-300 rounded-xl text-sm font-medium hover:bg-slate-700 transition-colors">
              <ChevronRight className="w-4 h-4" /> Voir les prix
            </button>
          </div>
        </motion.div>
      </div>
    </section>
  );
}


